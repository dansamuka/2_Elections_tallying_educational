# Core
ENGINE_ROOT=.
WORKER_ID=worker-a
PORTAL_INDEX_URL=https://forms.iebc.or.ke/index.php?l=2&p=2&r=site%2Findex
PORTAL_CONSTITUENCY=OL KALOU
PORTAL_CONSTITUENCY_CODE=091
PORTAL_COUNTY=NYANDARUA
PORTAL_DETAIL_URL=https://forms.iebc.or.ke/index.php?r=site%2Findex&id=141&ft=&p=2&es=
PORTAL_POLL_SECONDS=60
PORTAL_USER_AGENT=OlKalouCivicVerifier/0.2 (+https://example.org/methodology; contact@example.org)

# Safety gates. Keep false until the official candidate ballot order and full stream register are loaded.
ALLOW_INCOMPLETE_REFERENCE=false
AUTO_PUBLISH_MACHINE_VERIFIED=false
MACHINE_CONFIDENCE_THRESHOLD=0.95
# Replace after rehearsal calibration.
REJECTED_RATE_LOW=0.0
REJECTED_RATE_HIGH=0.05

# Review console
REVIEW_HOST=0.0.0.0
REVIEW_PORT=8080
REVIEW_API_TOKEN=change-me

# Public JSON output
PUBLIC_BASE_URL=http://localhost:8000/data/public
PUBLIC_OUTPUT=data/public/live.json

# Optional object storage (Cloudflare R2 / S3 compatible)
S3_ENDPOINT_URL=
S3_REGION=auto
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BASE_URL=
S3_PREFIX=ol-kalou

# Optional alerts
ALERT_WEBHOOK_URL=

# Optional OCR
OCR_MODE=none
GCV_CREDENTIALS_JSON=
# Selective Google Vision requests for already-localised handwritten number cells.
# Requests are capped per run and remain human-review evidence only.
GCV_CROP_MAX_REQUESTS=250
GCV_CROP_MAX_ATTEMPTS=3
GCV_CROP_TIMEOUT_SECONDS=20
GCV_CROP_MIN_LOCAL_CONFIDENCE=0.86
GCV_CROP_MIN_PREFILL_CONFIDENCE=0.65
AWS_REGION=af-south-1
FORM_ROI_MAP=data/reference/form35a_roi.json

# Always-on realtime sync API
# Use a long random value. It is never committed to frontend/config.js.
REALTIME_HOST=0.0.0.0
REALTIME_PORT=8090
REALTIME_API_TOKEN=change-me
REALTIME_SCHEDULER_ENABLED=true
# Ol Kalou is checked every 30 seconds. GitHub Actions remains a backup only.
REALTIME_POLL_SECONDS=30
# Historical benchmarks are intentionally slower and stay outside the live path.
REALTIME_ARCHIVE_POLL_SECONDS=300
REALTIME_TRIGGER_COOLDOWN_SECONDS=20
REALTIME_LIVE_ELECTION_ID=ol-kalou-2026
REALTIME_ELECTIONS=ol-kalou-2026
REALTIME_ENGINE=auto
REALTIME_CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,https://dansamuka.github.io
